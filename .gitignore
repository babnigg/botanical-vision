*.pyc
*.pyo
.venv/
venv/
env/

# Jupyter
.ipynb_checkpoints/

# Frontend (the separate demo app)
node_modules/
demo/web/dist/

# Kaggle push tooling — transient notebook copies + pulled outputs
kaggle/*.ipynb
kaggle/out/

# Model weights — training scratch is NOT shared
/checkpoints/
*.pt
*.pth
*.ckpt
*.safetensors

# Weights are shared via the HF model repo (see share/), never git — nothing under models/ is a weight.

